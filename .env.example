# Copy to .env on the server and adjust paths before running docker compose.

# Bind to 127.0.0.1 for SSH tunnel access, or to the server's VPN/LAN IP.
# Do not set this to 0.0.0.0 unless the host firewall blocks public access.
FINREP_BIND_ADDRESS=127.0.0.1

FINREP_DASH_PORT=8050
FINREP_DASH_DEBUG=0
FINREP_DASH_HOT_RELOAD=0

# Server paths that contain your real private data and generated reports.
FINREP_DATA_DIR=/srv/finrep/data
FINREP_REPORTS_DIR=/srv/finrep/reports
